# pet-atlas · 环境变量样例
# 复制为 .env.local(被 .gitignore 排除,不进 git)

# --- TCB CDN 图片 base URL(2026-07-19 切图到腾讯云)---
# Vercel 必须设 NEXT_PUBLIC_ATLAS_BASE_URL,build 时嵌入到 HTML
# 格式:https://<TCB 域名>/<project>
# 例:https://636c-cloud1-d9gv1q8ikad5e9721-1442530204.tcb.qcloud.la/pet-atlas
# 留空 = 走本地 public/ 静态资源(/dog/.../01-cover.png)
NEXT_PUBLIC_ATLAS_BASE_URL=
