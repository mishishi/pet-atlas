# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Vercel
.vercel

# Next.js / web
web/.next/
web/out/
web/node_modules/
scripts/node_modules/
web/.next-build-cache/
web/.turbo/
web/tsconfig.tsbuildinfo
web/next-env.d.ts
web/.swc/

# Build-generated 客户端数据(prebuild 时生成)
web/lib/pets-data.json

# 临时文件 / 缓存
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 编辑器 / IDE
.vscode/
.idea/
*.swp

# 操作系统
Thumbs.db

# ============================================
# 图片资源(1GB+,不进 git,部署时用云存储/CDN)
# ============================================
# AI 生成的图谱原图(300 张 × 2-3MB ≈ 700MB)
art/**/*.png
art/**/**/*.png
# web 构建用的图(从 art 同步过来,1GB)
web/public/**/*.png
web/public/**/**/*.png
# 设计稿(_design 目录下是早期图,也不进)
art/_design/*.png
# 参考图临时目录(被 image_synthesize 用过)
art/**/_ref/
art/**/**/_ref/

# 但 prompt 文档(.md)要进(记录每张图怎么生成的)
!art/**/*.md
!art/**/**/*.md
!web/public/**/*.md
!web/public/**/**/*.md

# 音频资源(预生成中文 TTS,~300K,走 TCB 存储不进 git,节省 Vercel build size)
web/public/**/*.mp3
web/public/**/**/*.mp3

# 内部脚本产物(可选)
scripts/atlas_requests.json
# scripts/vintage-paper-batch.json  ← 留着,记录 50 品种清单
# cloud-pet 预生成 prompt JSON(跑 node scripts/cloud-pet-gen-prompts.mjs 重新生成)
scripts/cloud-pet-pool.json

# 一次性测试脚本(诊断/调试用,不入仓)
web/scripts/test-*.mjs
web/scripts/diag-*.mjs

# Worktrees (临时开发分支,不入主仓库)
.worktrees/

# build artifacts
.next/
package-lock.json
web/.env.local
web/.env.local
.env*
